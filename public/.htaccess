# SPA Routing
# This ensures React Router works on Namecheap (Apache)
RewriteEngine On

# Temporarily disabled HTTPS redirect to stop warnings for the boss
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Handle Subdirectories & SPA routes
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ index.html [QSA,L]
